# Backend service env

# Server
PORT=8000

# SQLite path (resolved from packages/backend)
DATABASE_URL=./data/db.sqlite

# Better Auth (backend)
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:8000

# Agent runtime keys (required for recruiter/candidate AI routes)
GOOGLE_API_KEY=
GITHUB_TOKEN=

# Optional alternate LLM keys
OPENAI_API_KEY=
GROQ_API_KEY=
